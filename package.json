{
    "name": "space-tourism-website",
    "version": "1.2.0",
    "description": "🚀 Multi-page website for the Space Tourism company with responsive layout.",
    "private": true,
    "homepage": "https://github.com/aLeeTheY/Space-Tourism-Website#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/aLeeTheY/Space-Tourism-Website.git"
    },
    "bugs": {
        "url": "https://github.com/aLeeTheY/Space-Tourism-Website/issues"
    },
    "author": {
        "name": "Vladimir Nikulin",
        "email": "aleethey@gmail.com",
        "url": "https://github.com/aLeeTheY"
    },
    "license": "MIT",
    "type": "module",
    "devDependencies": {
        "@prettier/plugin-xml": "^3.4.2",
        "autoprefixer": "^10.5.0",
        "browser-sync": "^3.0.4",
        "chokidar-cli": "^3.0.0",
        "cross-env": "^10.1.0",
        "esbuild": "^0.28.0",
        "hint": "^7.1.13",
        "npm-run-all": "^4.1.5",
        "postcss-cli": "^11.0.1",
        "prettier": "^3.8.3",
        "prettier-plugin-jinja-template": "^2.2.0",
        "prettier-plugin-sh": "^0.18.1",
        "rimraf": "^6.1.3",
        "sass": "^1.100.0",
        "typescript": "^6.0.3"
    },
    "scripts": {
        "clean": "rimraf public/css public/js",
        "__SCSS__": "",
        "build:scss": "sass src/scss:public/css --embed-source-map && postcss public/css/*.css --use autoprefixer --env development --dir public/css",
        "build:scss:min": "sass src/scss:public/css/min --style=compressed --source-map && postcss public/css/min/*.css --use autoprefixer --env production --dir public/css/min --map",
        "__TYPESCRIPT__": "",
        "build:ts": "esbuild src/ts/*.ts --bundle --target=es2015 --outdir=public/js",
        "build:ts:min": "esbuild src/ts/*.ts --bundle --minify --sourcemap --target=es2015 --outdir=public/js/min",
        "__WATCH__": "",
        "watch:scss": "chokidar \"src/scss/**/*.scss\" -c \"npm run build:scss\"",
        "watch:ts": "chokidar \"src/ts/**/*.ts\" -c \"npm run build:ts\"",
        "watch": "npm-run-all --parallel watch:scss watch:ts",
        "__BUILD__": "",
        "build:debug": "npm-run-all --serial clean build:scss build:ts",
        "build:release": "npm-run-all --serial clean build:scss:min build:ts:min",
        "__SERVER__": "",
        "serve": "browser-sync start --server \"public\" --files \"public/**/*\"",
        "start": "npm-run-all --serial build:release serve"
    }
}
