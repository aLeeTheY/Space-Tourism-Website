{
    "name": "basic-website-template",
    "version": "1.0.0",
    "description": "Одностраничный сайт, сверстанный по макету из Figma. Реализована статическая кроссбраузерная верстка.",
    "private": true,
    "homepage": "https://github.com/npm/example#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/npm/example.git"
    },
    "author": {
        "name": "Vladimir Nikulin",
        "email": "mail.jorey@gmail.com",
        "url": "https://github.com/aBLeeWeeAN"
    },
    "license": "ISC",
    "type": "module",
    "devDependencies": {
        "autoprefixer": "^10.4.27",
        "chokidar-cli": "^3.0.0",
        "cross-env": "^10.1.0",
        "npm-run-all": "^4.1.5",
        "postcss-cli": "^11.0.1",
        "rimraf": "^6.1.3",
        "sass": "^1.98.0",
        "typescript": "^6.0.2"
    },
    "scripts": {
        "clean": "rimraf public/css public/js",
        "__SCSS__": "",
        "build:scss": "sass src/scss:public/css --no-source-map && postcss public/css/*.css --use autoprefixer --env development -d public/css",
        "build:scss:min": "sass src/scss:public/css/min --style=compressed --source-map && postcss public/css/min/*.css --use autoprefixer --env production --dir public/css/min --map",
        "__TYPESCRIPT__": "",
        "build:ts": "esbuild src/ts/*.ts --bundle --target=es2015 --outdir=public/js",
        "build:ts:min": "esbuild src/ts/*.ts --bundle --minify --sourcemap --target=es2015 --outdir=public/js/min",
        "__WATCH__": "",
        "watch:scss": "chokidar \"src/scss/**/*.scss\" -c \"npm run build:scss\"",
        "watch:scss:min": "chokidar \"src/scss/**/*.scss\" -c \"npm run build:scss:min\"",
        "watch:ts": "chokidar \"src/ts/**/*.ts\" -c \"npm run build:ts\"",
        "watch:ts:min": "chokidar \"src/ts/**/*.ts\" -c \"npm run build:ts:min\"",
        "watch": "npm-run-all --parallel watch:scss watch:ts watch:scss:min watch:ts:min",
        "__BUILD__": "",
        "build:debug": "npm-run-all --serial build:scss build:ts build:scss:min build:ts:min",
        "build:release": "npm-run-all --serial clean build:scss:min build:ts:min",
        "__SERVER__": "",
        "serve": "browser-sync start --server \"public\" --files \"public/**/*\"",
        "start": "npm-run-all --serial build:release serve"
    },
    "dependencies": {
        "browser-sync": "^3.0.4",
        "esbuild": "^0.27.4"
    }
}
